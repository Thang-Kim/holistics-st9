Dashboard dynamic_dashboard {
  title: 'Dynamic Dashboard'
  description: ''''''
  block title: TextBlock {
    content: @md # Your title goes here
<font color="#D2D5DF">(Double click to edit)</font>;;
  }
  block v1: VizBlock {
    label: 'cities'
    viz: ColumnChart {
      dataset: d_cities
      theme {

      }
      x_axis: VizFieldFull {
        ref: r(ecommerce_cities.country_code)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(ecommerce_cities.id)
            aggregation: 'count'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color_palette: 0
          }
        }
      }
      settings {
        x_axis_show_null_datetime: false
      }
    }
  }
  block v_5irp: VizBlock {
    label: 'cities copy'
    viz: DataTable {
      dataset: d_cities
      theme {
      }
      fields: [
        VizFieldFull {
          ref: r(ecommerce_cities.id)
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_cities.name)
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_cities.country_code)
          format {
            type: 'text'
          }
        }
      ]
      settings {
        show_row_number: true
      }
    }
  }
  view: TabLayout {
    label: 'View 1'
    tab view_1: CanvasLayout {
      label: 'Tab 1'
      height: 840
      grid_size: 20
      block v1 {
        position: pos(20, 160, 760, 540)
        layer: 1
      }
      block title {
        position: pos(20, 20, 1160, 120)
      }
    }
    tab tab_mum7: CanvasLayout {
      label: 'Tab 2'
      width: 460
      height: 340
      grid_size: 20
      auto_expand_vertically: true
      block v_5irp {
        position: pos(40, 20, 400, 300)
      }
      mobile {
        mode: 'auto'
      }
    }
  }
  theme: H.themes.classic
}