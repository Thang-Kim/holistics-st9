  data_source_name: 'staging9'
  dimension bathrooms {
    label: 'Bathrooms'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.bathrooms }};;
  }
  dimension price {
    label: 'Price'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.price }};;
  }
  dimension security_deposit {
    label: 'Security Deposit'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.security_deposit }};;
  }
  dimension cleaning_fee {
    label: 'Cleaning Fee'
    type: 'text'
    hidden: false
    definition: @sql {{ #SOURCE.cleaning_fee }};;
  }

  owner: 'tung.bt@holistics.io'
  table_name: '"upload"."test_mongo"'
}
